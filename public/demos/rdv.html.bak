<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Salon Éclat — Beauté & Bien-être</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#faf8f6;--card:#fff;--accent:#b76e79;--accent2:#fdf0f1;--teal:#0d9488;--text:#2d1f22;--muted:#9b8c8f;--border:#ede8e6;--green:#059669;--red:#dc2626}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;line-height:1.6;overflow-x:hidden}

/* NAV */
nav{background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:1rem 2.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--text)}
.logo span{color:var(--accent)}
.nav-links{display:flex;gap:1.5rem}
.nav-links a{font-size:13px;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--accent)}
.nav-cta{padding:9px 22px;background:linear-gradient(135deg,var(--accent),#d4919a);color:white;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;border:none;cursor:pointer;font-family:inherit}

/* HERO */
.hero{min-height:90vh;display:grid;grid-template-columns:1fr 1fr;gap:0;overflow:hidden}
.hero-left{background:linear-gradient(135deg,#faf5ff 0%,#ede9fe 100%);padding:5rem 3rem 4rem;display:flex;flex-direction:column;justify-content:center}
.hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);color:var(--accent);font-size:12px;font-weight:600;padding:5px 14px;border-radius:100px;margin-bottom:1.5rem;width:fit-content}
.live-dot{width:7px;height:7px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px #22c55e;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(2.5rem,4vw,3.5rem);font-weight:800;line-height:1.05;margin-bottom:1rem;letter-spacing:-.03em}
.hero h1 span{color:var(--accent)}
.hero p{color:var(--muted);font-weight:300;max-width:420px;margin-bottom:2rem;line-height:1.75}
.hero-stats{display:flex;gap:2rem;margin-top:2.5rem;padding-top:2rem;border-top:1px solid rgba(124,58,237,.15)}
.hero-stat strong{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--accent);display:block;line-height:1}
.hero-stat span{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.hero-right{position:relative;overflow:hidden}
.hero-right img{width:100%;height:100%;object-fit:cover}
.hero-right-overlay{position:absolute;bottom:2rem;left:2rem;right:2rem}
.hero-booking-card{background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-radius:16px;padding:1.25rem;border:1px solid var(--border)}

/* LOYALTY BAR */
.loyalty-bar{background:linear-gradient(135deg,var(--accent),#d4919a);color:white;text-align:center;padding:10px 1rem;font-size:13px;font-weight:500}
.loyalty-bar strong{color:#e9d5ff}

/* SECTION */
.section{padding:5rem 2.5rem;max-width:1200px;margin:0 auto}
.sec-eyebrow{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:.5rem}
.sec-title{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:800;letter-spacing:-.02em;margin-bottom:.75rem}
.sec-desc{color:var(--muted);font-weight:300;max-width:500px;margin-bottom:2.5rem}
.divider{max-width:1200px;margin:0 auto;border:none;border-top:1px solid var(--border)}

/* BEFORE / AFTER */
.ba-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
.ba-card{border-radius:14px;overflow:hidden;position:relative;cursor:pointer}
.ba-card img{width:100%;height:220px;object-fit:cover;display:block}
.ba-label{position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,.7);color:white;font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;backdrop-filter:blur(4px)}
.ba-service{position:absolute;top:10px;right:10px;background:var(--accent);color:white;font-size:10px;font-weight:700;padding:3px 9px;border-radius:100px}
.ba-result{position:absolute;top:10px;left:10px;background:rgba(255,255,255,.9);color:var(--text);font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;display:none}
.ba-card:hover .ba-result{display:block}
.ba-card:hover .ba-label{display:none}

/* SERVICES */
.services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.svc-card{background:white;border:1.5px solid var(--border);border-radius:14px;padding:1.25rem;text-align:center;cursor:pointer;transition:all .2s;position:relative}
.svc-card:hover,.svc-card.active{border-color:var(--accent);background:var(--accent2);transform:translateY(-2px)}
.svc-emoji{font-size:2rem;margin-bottom:8px;display:block}
.svc-name{font-weight:700;font-size:14px;margin-bottom:4px}
.svc-dur{font-size:12px;color:var(--muted)}
.svc-price{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:var(--accent);margin-top:6px}
.popular-tag{position:absolute;top:-6px;right:10px;background:var(--accent);color:white;font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px}

/* PACKAGES */
.packs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px}
.pack-card{background:white;border:1.5px solid var(--border);border-radius:16px;padding:1.5rem;position:relative;transition:all .2s}
.pack-card:hover{border-color:var(--accent);box-shadow:0 6px 20px rgba(124,58,237,.1)}
.pack-card.featured{border-color:var(--accent);background:var(--accent2)}
.pack-badge{position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:var(--accent);color:white;font-size:10px;font-weight:700;padding:3px 12px;border-radius:100px;white-space:nowrap}
.pack-items{margin:1rem 0;display:flex;flex-direction:column;gap:5px}
.pack-item{font-size:13px;display:flex;align-items:center;gap:6px;color:var(--text)}
.pack-price{display:flex;align-items:center;gap:8px;margin-top:1rem}
.pack-old{font-size:13px;color:var(--muted);text-decoration:line-through}
.pack-new{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:var(--accent)}
.pack-saving{font-size:12px;color:var(--teal);font-weight:600}

/* BOOKING */
.booking-layout{display:grid;grid-template-columns:1fr 1.1fr;gap:2rem;align-items:start}
.booking-block{background:white;border:1px solid var(--border);border-radius:18px;padding:1.75rem}
.block-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:8px}

/* CALENDAR */
.cal-nav-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem}
.cal-month-lbl{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem}
.cal-nav-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:8px;background:none;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.cal-nav-btn:hover{border-color:var(--accent);color:var(--accent)}
.cal-wdays{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px}
.cal-wday{text-align:center;font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding:4px 0}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:9px;font-size:13px;transition:all .15s;color:var(--muted);border:1.5px solid transparent}
.cal-day.in-month{color:var(--text)}
.cal-day.available{cursor:pointer}
.cal-day.available:hover{background:var(--accent2);color:var(--accent)}
.cal-day.selected{background:var(--accent);color:white;font-weight:700}
.cal-day.unavailable{opacity:.25;pointer-events:none}
.slots-sec{margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);display:none}
.slots-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:.75rem}
.filter-btn{padding:6px 16px;border:1.5px solid var(--border);border-radius:100px;font-size:12px;color:var(--muted);background:white;cursor:pointer;font-family:inherit;font-weight:500;transition:all .2s}
.filter-btn.active,.filter-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent2)}
.filter-btn.active{font-weight:700}
.slot{padding:9px 6px;border:1.5px solid var(--border);border-radius:9px;text-align:center;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;background:white;position:relative}
.slot:hover{border-color:var(--accent);background:var(--accent2);color:var(--accent)}
.slot.selected{background:var(--accent);color:white;border-color:var(--accent)}
.slot.full{background:var(--bg);color:var(--muted);cursor:not-allowed;text-decoration:line-through}
.slot-tag{position:absolute;top:-5px;right:4px;background:var(--teal);color:white;font-size:8px;padding:1px 5px;border-radius:3px}

/* FORM */
.form-group{margin-bottom:12px}
.form-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);display:block;margin-bottom:5px}
.form-input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:inherit;color:var(--text);background:var(--bg);outline:none;transition:all .2s}
.form-input:focus{border-color:var(--accent);background:white;box-shadow:0 0 0 3px rgba(124,58,237,.08)}
.form-input::placeholder{color:var(--muted)}
.summary-box{background:var(--accent2);border:1.5px solid rgba(124,58,237,.2);border-radius:12px;padding:1rem;margin:1rem 0}
.sum-row{display:flex;justify-content:space-between;padding:4px 0;font-size:13px;border-bottom:1px solid rgba(124,58,237,.1)}
.sum-row:last-child{border-bottom:none;font-weight:700;padding-top:8px}
.deposit-notice{background:rgba(13,148,136,.08);border:1px solid rgba(13,148,136,.2);border-radius:10px;padding:.75rem 1rem;font-size:12px;color:var(--teal);margin:.75rem 0;line-height:1.6}
.btn-confirm{width:100%;padding:13px;background:linear-gradient(135deg,var(--accent),#d4919a);color:white;border:none;border-radius:12px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(124,58,237,.3);transition:opacity .2s}
.btn-confirm:hover{opacity:.9}
.btn-confirm:disabled{opacity:.5;cursor:not-allowed}
.alert{padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:10px;display:none;line-height:1.5}
.alert-success{background:rgba(5,150,105,.08);border:1px solid rgba(5,150,105,.2);color:var(--green)}
.alert-error{background:rgba(220,38,38,.08);border:1px solid rgba(220,38,38,.2);color:var(--red)}

/* TEAM */
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}
.team-card{background:white;border:1px solid var(--border);border-radius:18px;overflow:hidden;transition:all .2s;cursor:pointer}
.team-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.08);transform:translateY(-4px)}
.team-img{height:200px;overflow:hidden}
.team-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.team-card:hover .team-img img{transform:scale(1.04)}
.team-body{padding:1.1rem}
.team-name{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:2px}
.team-role{font-size:12px;color:var(--accent);font-weight:600;margin-bottom:6px}
.team-specs{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px}
.team-spec{font-size:10px;padding:2px 8px;border-radius:100px;background:var(--accent2);color:var(--accent);font-weight:600}
.team-rating{font-size:12px;color:var(--muted);margin-top:6px}

/* AVIS */
.avis-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.avis-card{background:white;border:1px solid var(--border);border-radius:14px;padding:1.1rem}
.avis-stars{color:#fbbf24;font-size:13px;margin-bottom:6px}
.avis-text{font-size:13px;color:var(--text);font-style:italic;line-height:1.6;margin-bottom:8px}
.avis-author{font-size:12px;color:var(--muted);font-weight:600}

/* FAQ */
.faq-list{max-width:700px;display:flex;flex-direction:column;gap:8px}
.faq-q{padding:1rem 1.25rem;background:white;border:1px solid var(--border);border-radius:12px;font-size:14px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:all .2s;user-select:none}
.faq-q:hover,.faq-q.open{border-color:var(--accent);color:var(--accent)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s ease,padding .3s;font-size:13px;color:var(--muted);line-height:1.7;padding:0 1.25rem;background:white;border:1px solid transparent;border-top:none;border-radius:0 0 12px 12px;margin-top:-4px}
.faq-a.open{max-height:200px;padding:.75rem 1.25rem 1rem;border-color:var(--accent);border-top:none}

footer{background:var(--text);color:rgba(255,255,255,.6);padding:2rem;text-align:center;font-size:12px}
footer strong{color:#a78bfa}

.back-btn{position:fixed;bottom:24px;right:24px;z-index:200;background:linear-gradient(135deg,var(--accent),#d4919a);color:white;padding:10px 18px;font-size:12px;font-family:inherit;font-weight:600;border-radius:10px;text-decoration:none;box-shadow:0 4px 14px rgba(124,58,237,.35)}
.admin-lnk{position:fixed;bottom:24px;left:24px;z-index:200;background:white;color:var(--accent);border:1px solid var(--accent);padding:10px 18px;font-size:12px;font-family:inherit;font-weight:600;border-radius:10px;text-decoration:none}
.btn{padding:10px 24px;border-radius:10px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:opacity .2s;display:inline-flex;align-items:center;gap:7px}
.btn-primary{background:linear-gradient(135deg,var(--accent),#d4919a);color:white;box-shadow:0 4px 14px rgba(124,58,237,.25)}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--text)}

@media(max-width:900px){
  .hero{grid-template-columns:1fr}.hero-right{display:none}
  .booking-layout{grid-template-columns:1fr}
  .section{padding:3rem 1.25rem}
  nav{padding:1rem 1.25rem}.nav-links{display:none}
}
select{background:#0a0a12!important;color:#fff!important;color-scheme:dark}
select option{background:#0a0a12!important;color:#fff!important}
</style>
</head>
<body>

<!-- LOYALTY BAR -->
<div class="loyalty-bar">💜 Programme fidélité : <strong>5ème visite offerte</strong> · Parrainez un(e) ami(e) = <strong>10€ offerts</strong> à vous deux</div>

<nav>
  <div class="logo">Salon <span>Éclat</span></div>
  <div class="nav-links">
    <a href="#avant-apres">Avant/Après</a>
    <a href="#services">Prestations</a>
    <a href="#packs">Formules</a>
    <a href="#booking">Réserver</a>
    <a href="#equipe">Équipe</a>
  </div>
  <a href="#booking" class="nav-cta">Prendre RDV</a>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-left">
    <div class="hero-badge"><span class="live-dot"></span> Réservation en ligne 24h/24</div>
    <h1>Votre beauté,<br><span>sublimée.</span></h1>
    <p>Coloristes expertes, soins premium, résultats garantis. Réservez votre créneau en 60 secondes, annulation gratuite jusqu'à 24h avant.</p>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a href="#booking" class="btn btn-primary">📅 Prendre rendez-vous</a>
      <a href="#avant-apres" class="btn btn-outline">Voir nos réalisations</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><strong>500+</strong><span>Clientes fidèles</span></div>
      <div class="hero-stat"><strong>10 ans</strong><span>D'expertise</span></div>
      <div class="hero-stat"><strong>4.9 ⭐</strong><span>Note Google</span></div>
      <div class="hero-stat"><strong>0</strong><span>No-show</span></div>
    </div>
  </div>
  <div class="hero-right">
    <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=80" alt="Salon Éclat">
    <div class="hero-right-overlay">
      <div class="hero-booking-card">
        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:.75rem">⚡ Réservation rapide</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <select id="quick-svc" style="flex:1;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:inherit;font-size:13px;outline:none;background:white;color:var(--text)" onchange="quickSelectSvc(this.value)">
            <option value="">Choisir une prestation...</option>
            <option value="Coupe femme">Coupe femme — 45€</option>
            <option value="Couleur complète">Couleur — 85€</option>
            <option value="Balayage">Balayage — 120€</option>
            <option value="Soin profond">Soin profond — 35€</option>
          </select>
          <a href="#booking" style="padding:9px 16px;background:var(--accent);color:white;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap">Voir les créneaux →</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- AVANT / APRÈS -->
<div class="section" id="avant-apres">
  <div class="sec-eyebrow">Nos réalisations</div>
  <div class="sec-title">Avant / Après</div>
  <div class="sec-desc">Des transformations réelles réalisées par notre équipe. Survolez pour voir le résultat.</div>
  <div class="ba-grid" id="ba-grid"></div>
</div>
<hr class="divider">

<!-- SOINS -->
<div class="section" id="services">
  <div class="sec-eyebrow">Réservation en ligne</div>
  <div class="sec-title">Choisissez vos soins</div>
  <div class="sec-desc">Sélectionnez une ou plusieurs prestations — le total et la durée se calculent automatiquement.</div>
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.5rem">
    <button class="filter-btn active" onclick="filterSoins('tous',this)">Tous</button>
    <button class="filter-btn" onclick="filterSoins('Coupe',this)">Coupes</button>
    <button class="filter-btn" onclick="filterSoins('Couleur',this)">Couleurs</button>
    <button class="filter-btn" onclick="filterSoins('Soin',this)">Soins</button>
    <button class="filter-btn" onclick="filterSoins('Spécial',this)">Occasions</button>
  </div>
  <div id="soins-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px;margin-bottom:1.5rem"></div>
  <div id="selection-bar" style="display:none;background:var(--accent2);border:1.5px solid rgba(183,110,121,.25);border-radius:14px;padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
    <div>
      <div style="font-weight:700;font-size:13px;color:var(--text);margin-bottom:4px" id="sel-summary">Aucune prestation sélectionnée</div>
      <div style="font-size:12px;color:var(--muted)" id="sel-details"></div>
    </div>
    <div style="display:flex;align-items:center;gap:10px">
      <div style="text-align:right">
        <div style="font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--accent)" id="sel-total">0 €</div>
        <div style="font-size:11px;color:var(--muted)" id="sel-duration">0 min</div>
      </div>
      <a href="#booking" class="nav-cta" id="sel-cta" onclick="scrollToBooking()">Réserver →</a>
    </div>
  </div>
</div>
<hr class="divider">

<!-- BOOKING -->
<div class="section" id="booking">
  <div class="sec-eyebrow">Prise de rendez-vous</div>
  <div class="sec-title">Réservez votre créneau</div>
  <div class="sec-desc">Confirmation immédiate · Rappel 24h avant · Annulation gratuite</div>
  <div class="booking-layout">
    <div>
      <div class="booking-block">
        <div class="block-title">📅 Choisissez une date</div>
        <div class="cal-nav-row">
          <button class="cal-nav-btn" id="cal-prev">‹</button>
          <span class="cal-month-lbl" id="cal-month"></span>
          <button class="cal-nav-btn" id="cal-next">›</button>
        </div>
        <div class="cal-wdays">
          <div class="cal-wday">L</div><div class="cal-wday">M</div><div class="cal-wday">M</div>
          <div class="cal-wday">J</div><div class="cal-wday">V</div>
          <div class="cal-wday" style="color:#ef4444">S</div><div class="cal-wday" style="color:#ef4444">D</div>
        </div>
        <div class="cal-grid" id="cal-days"></div>
        <div class="slots-sec" id="slots-sec">
          <div style="font-size:13px;font-weight:600;color:var(--text)" id="slots-label">Créneaux disponibles</div>
          <div class="slots-grid" id="slots-grid"></div>
        </div>
      </div>
    </div>
    <div>
      <div class="booking-block">
        <div class="block-title">📝 Vos informations</div>
        <div class="alert alert-success" id="bk-success"></div>
        <div class="alert alert-error" id="bk-error"></div>
        <form id="bk-form" onsubmit="submitBooking(event)">
          <div class="form-group"><label class="form-label">Prénom & Nom *</label><input name="name" class="form-input" placeholder="Marie Dupont" required></div>
          <div class="form-group"><label class="form-label">Email *</label><input name="email" type="email" class="form-input" placeholder="marie@email.com" required></div>
          <div class="form-group"><label class="form-label">Téléphone</label><input name="phone" class="form-input" placeholder="06 12 34 56 78"></div>
          <div class="form-group"><label class="form-label">Praticienne</label>
            <select name="practitioner" class="form-input">
              <option>Pas de préférence</option>
              <option>Sophie M. — Coloriste</option>
              <option>Lucie B. — Coiffeuse</option>
              <option>Camille P. — Styliste</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Notes</label><textarea name="notes" class="form-input" rows="2" placeholder="Allergies, souhaits particuliers..."></textarea></div>
          <div class="summary-box">
            <div class="sum-row"><span style="color:var(--muted)">Prestation</span><span style="font-weight:600" id="sum-svc">—</span></div>
            <div class="sum-row"><span style="color:var(--muted)">Date</span><span style="font-weight:600" id="sum-date">—</span></div>
            <div class="sum-row"><span style="color:var(--muted)">Heure</span><span style="font-weight:600" id="sum-time">—</span></div>
            <div class="sum-row"><span style="color:var(--muted)">Durée</span><span style="font-weight:600" id="sum-dur">—</span></div>
            <div class="sum-row"><span>Prix total</span><span style="color:var(--accent)" id="sum-price">—</span></div>
          </div>
          <div class="deposit-notice">🔒 <strong>Acompte de 20% requis</strong> à la réservation (via Stripe sécurisé). Remboursé intégralement en cas d'annulation 24h avant. Réduit les no-show de 70%.</div>
          <button type="submit" class="btn-confirm" id="bk-submit">✅ Confirmer et payer l'acompte</button>
        </form>
      </div>
    </div>
  </div>
</div>
<hr class="divider">

<!-- EQUIPE -->
<div class="section" id="equipe">
  <div class="sec-eyebrow">Notre équipe</div>
  <div class="sec-title">Des expertes à votre service</div>
  <div class="sec-desc">Chacune formée aux dernières techniques, passionnée par son métier.</div>
  <div class="team-grid" id="team-grid"></div>
</div>
