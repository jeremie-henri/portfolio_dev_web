<script>
const MONTHS=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre']
const SERVICES_DATA=[
  {emoji:'✂️',nom:'Coupe femme',categorie:'Coupe',dur:45,prix:45,popular:true},
  {emoji:'💈',nom:'Coupe homme',categorie:'Coupe',dur:30,prix:28,popular:false},
  {emoji:'🎨',nom:'Couleur complète',categorie:'Couleur',dur:90,prix:85,popular:false},
  {emoji:'✨',nom:'Balayage',categorie:'Couleur',dur:120,prix:120,popular:true},
  {emoji:'💆',nom:'Soin profond',categorie:'Soin',dur:30,prix:35,popular:false},
  {emoji:'💅',nom:'Brushing & Mise en plis',categorie:'Soin',dur:45,prix:40,popular:false},
  {emoji:'🌈',nom:'Mèches & Highlights',categorie:'Couleur',dur:90,prix:95,popular:false},
  {emoji:'💍',nom:'Coiffage mariage',categorie:'Spécial',dur:120,prix:150,popular:false},
  {emoji:'🎭',nom:'Coiffure événement',categorie:'Spécial',dur:60,prix:80,popular:false},
]
const PACKAGES=[
  {name:'Pack Éclat Total',items:['Coupe femme','Couleur complète','Soin profond'],old:165,price:139,saving:'15%',badge:'Le plus populaire',featured:true},
  {name:'Pack Couleur & Soin',items:['Balayage','Soin profond','Brushing'],old:155,price:135,saving:'13%',badge:'Nouveau'},
  {name:'Pack Beauté Rapide',items:['Coupe femme','Soin express'],old:70,price:60,saving:'14%',badge:'Idéal 1h30'},
]
const TEAM_DATA=[
  {name:'Sophie Martin',role:'Coloriste experte',spec:['Balayage','Couleur','Mèches'],exp:'8 ans',rating:'4.9',img:'https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=400&q=75'},
  {name:'Lucie Bernard',role:'Coiffeuse styliste',spec:['Coupes','Brushing','Chignons'],exp:'5 ans',rating:'4.8',img:'https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=400&q=75'},
  {name:'Camille Petit',role:'Styliste mariages',spec:['Mariages','Soirées','Tresses'],exp:'6 ans',rating:'5.0',img:'https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?w=400&q=75'},
  {name:'Emma Rousseau',role:'Esthéticienne',spec:['Soins visage','Sourcils','Maquillage'],exp:'4 ans',rating:'4.7',img:'https://images.unsplash.com/photo-1548142813-c348350df52b?w=400&q=75'},
]
const BA_DATA=[
  {service:'Balayage',
   before:'https://images.unsplash.com/photo-1620331311520-246422fd82f9?w=400&q=75',
   after:'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400&q=75',
   desc:'Balayage naturel — résultat lumineux'},
  {service:'Couleur',
   before:'https://images.unsplash.com/photo-1634449571010-02389ed0f9b0?w=400&q=75',
   after:'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=400&q=75',
   desc:'Couleur châtain doré — reflets miel'},
  {service:'Coupe',
   before:'https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?w=400&q=75',
   after:'https://images.unsplash.com/photo-1562322140-8baeececf3df?w=400&q=75',
   desc:'Coupe structurée — volume et légèreté'},
  {service:'Soin',
   before:'https://images.unsplash.com/photo-1626954079979-ec4ac6899e8b?w=400&q=75',
   after:'https://images.unsplash.com/photo-1519741347686-c1e0aadf4611?w=400&q=75',
   desc:'Soin kératine — brillance et douceur'},
]
const AVIS_DATA=[
  {stars:5,text:'"Sophie est une magicienne du balayage. Résultat naturel et lumineux, exactement ce que je voulais. Je n\'irai plus nulle part ailleurs !"',author:'Marie L. · Balayage'},
  {stars:5,text:'"L\'appli de RDV est super pratique. Je réserve depuis mon téléphone en 2 minutes. L\'équipe est super professionnelle."',author:'Claire R. · Coupe femme'},
  {stars:5,text:'"Coiffure de mariage parfaite, tenue toute la journée. Camille a su exactement ce que je voulais. Merci !"',author:'Justine M. · Coiffage mariage'},
  {stars:4,text:'"Très bonne expérience, salon agréable et équipe souriante. Juste un peu d\'attente malgré le RDV, mais résultat au top."',author:'Nathalie V. · Couleur'},
  {stars:5,text:'"Le soin profond a transformé mes cheveux secs. Lucie m\'a donné plein de conseils pour l\'entretien. Super !"',author:'Isabelle D. · Soin profond'},
  {stars:5,text:'"Pack Éclat Total, c\'est la vie. 3h de bonheur à un prix imbattable. Le programme fidélité est un vrai plus."',author:'Sophie T. · Pack Éclat Total'},
]
const FAQ_DATA=[
  {q:'Comment annuler mon rendez-vous ?',a:'Vous pouvez annuler gratuitement jusqu\'à 24h avant votre RDV en répondant à votre email de confirmation. En-dessous de 24h, l\'acompte est conservé.'},
  {q:'L\'acompte est-il remboursable ?',a:'Oui, intégralement si l\'annulation intervient plus de 24h avant. L\'acompte représente 20% du prix de la prestation.'},
  {q:'Puis-je venir sans rendez-vous ?',a:'Nous acceptons les clients sans RDV selon disponibilité, mais la réservation est fortement recommandée pour garantir votre créneau.'},
  {q:'Quels sont les moyens de paiement ?',a:'Nous acceptons CB, espèces, sans contact, Apple Pay et chèques-cadeaux Salon Éclat.'},
  {q:'Proposez-vous des cartes cadeaux ?',a:'Oui ! Cartes cadeaux disponibles en salon pour tous montants. Idéales pour offrir un moment de beauté.'},
]

let selectedSoins=[], selDate=null, selSlot=null, curDate=new Date(2026,5,1), filterCat='tous'


function renderBA(){
  var grid = document.getElementById('ba-grid')
  if (!grid) return
  grid.innerHTML = ''
  BA_DATA.forEach(function(b) {
    var card = document.createElement('div')
    card.className = 'ba-card'
    card.style.cssText = 'position:relative;border-radius:14px;overflow:hidden;cursor:pointer;height:260px'
    
    // Image "Avant" visible par défaut
    var imgBefore = document.createElement('img')
    imgBefore.src = b.before
    imgBefore.alt = 'Avant ' + b.service
    imgBefore.loading = 'lazy'
    imgBefore.className = 'ba-img-before'
    imgBefore.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:opacity .4s'
    
    // Image "Après" cachée par défaut
    var imgAfter = document.createElement('img')
    imgAfter.src = b.after
    imgAfter.alt = 'Après ' + b.service
    imgAfter.loading = 'lazy'
    imgAfter.className = 'ba-img-after'
    imgAfter.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .4s'
    
    // Badge service
    var svcBadge = document.createElement('span')
    svcBadge.style.cssText = 'position:absolute;top:10px;right:10px;background:var(--accent);color:white;font-size:10px;font-weight:700;padding:3px 10px;border-radius:100px;z-index:3'
    svcBadge.textContent = b.service
    
    // Label Avant
    var lblBefore = document.createElement('span')
    lblBefore.style.cssText = 'position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,.6);color:white;font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;backdrop-filter:blur(4px);z-index:3;transition:opacity .3s'
    lblBefore.textContent = '← Avant'
    
    // Label Après
    var lblAfter = document.createElement('span')
    lblAfter.style.cssText = 'position:absolute;bottom:10px;right:10px;background:var(--accent);color:white;font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;z-index:3;opacity:0;transition:opacity .3s'
    lblAfter.textContent = 'Après ✨'
    
    // Description résultat
    var desc = document.createElement('div')
    desc.style.cssText = 'position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.7));color:white;font-size:12px;font-weight:600;padding:.75rem 1rem;opacity:0;transition:opacity .3s;z-index:3'
    desc.textContent = b.desc
    
    card.appendChild(imgBefore)
    card.appendChild(imgAfter)
    card.appendChild(svcBadge)
    card.appendChild(lblBefore)
    card.appendChild(lblAfter)
    card.appendChild(desc)
    
    card.addEventListener('mouseenter', function() {
      imgBefore.style.opacity = '0'
      imgAfter.style.opacity = '1'
      lblBefore.style.opacity = '0'
      lblAfter.style.opacity = '1'
      desc.style.opacity = '1'
    })
    card.addEventListener('mouseleave', function() {
      imgBefore.style.opacity = '1'
      imgAfter.style.opacity = '0'
      lblBefore.style.opacity = '1'
      lblAfter.style.opacity = '0'
      desc.style.opacity = '0'
    })
    
    grid.appendChild(card)
  })
}

function renderServices(){
  document.getElementById('services-grid').innerHTML=SERVICES_DATA.map((s,i)=>`
    <div class="svc-card${selSvc===i?' active':''}" onclick-removed>
      ${s.popular?'<span class="popular-tag">⭐ Populaire</span>':''}
      <span class="svc-emoji">${s.emoji}</span>
      <div class="svc-name">${s.name}</div>
      <div class="svc-dur">${s.dur} min</div>
      <div class="svc-price">${s.price} €</div>
    </div>`).join('')
}

function selectSvc(i){
  selSvc=i;const s=SERVICES_DATA[i]
  document.getElementById('sum-svc').textContent=s.name
  document.getElementById('sum-dur').textContent=s.dur+' min'
  document.getElementById('sum-price').textContent=s.price+' € (acompte '+Math.round(s.price*.2)+' €)'
  renderServices()
  document.getElementById('booking').scrollIntoView({behavior:'smooth'})
}


function selectPackage(name,price){
  // Trouver la durée totale du pack (somme des services)
  const packDurations = {
    "Pack Éclat Total": "3h00 (coupe + couleur + soin)",
    "Pack Couleur & Soin": "2h30 (balayage + soin + brushing)",
    "Pack Beauté Rapide": "1h15 (coupe + soin express)"
  }
  document.getElementById('sum-svc').textContent = name
  document.getElementById('sum-dur').textContent = packDurations[name] || "Voir détail"
  document.getElementById('sum-price').textContent = price + ' € (acompte ' + Math.round(price*.2) + ' €)'
  // Date et heure restent à sélectionner — on guide l'utilisateur
  document.getElementById('sum-date').textContent = '— Sélectionnez une date'
  document.getElementById('sum-time').textContent = '— Sélectionnez un créneau'
  document.getElementById('booking').scrollIntoView({behavior:'smooth'})
}

function renderTeam(){
  document.getElementById('team-grid').innerHTML=TEAM_DATA.map(t=>`
    <div class="team-card">
      <div class="team-img"><img src="${t.img}" alt="${t.name}" loading="lazy"></div>
      <div class="team-body">
        <div class="team-name">${t.name}</div>
        <div class="team-role">${t.role}</div>
        <div class="team-specs">${t.spec.map(s=>`<span class="team-spec">${s}</span>`).join('')}</div>
        <div class="team-rating">⭐ ${t.rating} · ${t.exp} d'expérience</div>
      </div>
    </div>`).join('')
}

function renderAvis(){
  document.getElementById('avis-grid').innerHTML=AVIS_DATA.map(a=>`
    <div class="avis-card">
      <div class="avis-stars">${'★'.repeat(a.stars)}${'☆'.repeat(5-a.stars)}</div>
      <div class="avis-text">${a.text}</div>
      <div class="avis-author">${a.author}</div>
    </div>`).join('')
}

function renderFAQ(){
  document.getElementById('faq-list').innerHTML=FAQ_DATA.map((f,i)=>`
    <div>
      <div class="faq-q" id="fq-${i}" onclick="toggleFaq(${i})">${f.q} <span>▾</span></div>
      <div class="faq-a" id="fa-${i}">${f.a}</div>
    </div>`).join('')
}
function toggleFaq(i){
  const q=document.getElementById('fq-'+i),a=document.getElementById('fa-'+i)
  const open=q.classList.contains('open')
  document.querySelectorAll('.faq-q').forEach(e=>e.classList.remove('open'))
  document.querySelectorAll('.faq-a').forEach(e=>e.classList.remove('open'))
  if(!open){q.classList.add('open');a.classList.add('open')}
}

// CALENDAR



function quickSelectSvc(nomSvc) {
  if (!nomSvc) return;
  var s = SERVICES_DATA.find(function(x) { return x.nom === nomSvc; });
  if (!s) return;
  selectedSoins = [s];
  updateSelectionBar();
  updateBookingSummary();
  renderSoins();
  document.getElementById('booking').scrollIntoView({ behavior: 'smooth' });
}

function renderSoins(filter) {
  filter = filter || filterCat;
  var list = filter === 'tous'
    ? SERVICES_DATA
    : SERVICES_DATA.filter(function(s) { return s.categorie === filter; });
  var grid = document.getElementById('soins-grid');
  if (!grid) return;
  grid.innerHTML = '';
  list.forEach(function(s) {
    var isSel = selectedSoins.some(function(x) { return x.nom === s.nom; });
    var card = document.createElement('div');
    card.style.background = 'white';
    card.style.border = '1.5px solid ' + (isSel ? 'var(--accent)' : 'var(--border)');
    card.style.borderRadius = '14px';
    card.style.padding = '1.25rem';
    card.style.cursor = 'pointer';
    card.style.transition = 'all .2s';
    card.style.position = 'relative';
    if (isSel) card.style.background = 'var(--accent2)';

    if (s.popular) {
      var pop = document.createElement('span');
      pop.style.cssText = 'position:absolute;top:-7px;right:10px;background:var(--accent);color:white;font-size:9px;font-weight:700;padding:2px 9px;border-radius:100px';
      pop.textContent = 'Populaire';
      card.appendChild(pop);
    }
    if (isSel) {
      var check = document.createElement('div');
      check.style.cssText = 'position:absolute;top:10px;right:10px;width:22px;height:22px;border-radius:50%;background:var(--accent);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700';
      check.textContent = '✓';
      card.appendChild(check);
    }

    var emoji = document.createElement('span');
    emoji.style.cssText = 'font-size:2rem;display:block;margin-bottom:8px';
    emoji.textContent = s.emoji;
    card.appendChild(emoji);

    var name = document.createElement('div');
    name.style.cssText = 'font-weight:700;font-size:14px;margin-bottom:4px;padding-right:26px';
    name.textContent = s.nom;
    card.appendChild(name);

    var dur = document.createElement('div');
    dur.style.cssText = 'font-size:12px;color:var(--muted);margin-bottom:8px';
    dur.textContent = s.dur + ' min';
    card.appendChild(dur);

    var price = document.createElement('div');
    price.style.cssText = 'font-size:1rem;font-weight:800;color:var(--accent)';
    price.textContent = s.prix + ' €';
    card.appendChild(price);

    card.addEventListener('click', (function(soin) {
      return function() { toggleSoin(soin); };
    })(s));
    grid.appendChild(card);
  });
}

function filterSoins(cat, el) {
  filterCat = cat;
  document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
  if (el) el.classList.add('active');
  renderSoins(cat);
}

function toggleSoin(s) {
  var idx = selectedSoins.findIndex(function(x) { return x.nom === s.nom; });
  if (idx >= 0) { selectedSoins.splice(idx, 1); }
  else { selectedSoins.push(s); }
  renderSoins();
  updateSelectionBar();
  updateBookingSummary();
}

function updateSelectionBar() {
  var bar = document.getElementById('selection-bar');
  var summary = document.getElementById('sel-summary');
  var details = document.getElementById('sel-details');
  var totalEl = document.getElementById('sel-total');
  var durEl = document.getElementById('sel-duration');
  if (!bar) return;
  if (selectedSoins.length === 0) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';
  var totalPrice = selectedSoins.reduce(function(a, s) { return a + s.prix; }, 0);
  var totalDur = selectedSoins.reduce(function(a, s) { return a + s.dur; }, 0);
  if (summary) summary.textContent = selectedSoins.length + ' soin' + (selectedSoins.length > 1 ? 's' : '') + ' sélectionné' + (selectedSoins.length > 1 ? 's' : '');
  if (details) details.textContent = selectedSoins.map(function(s) { return s.nom; }).join(' + ');
  if (totalEl) totalEl.textContent = totalPrice + ' €';
  if (durEl) durEl.textContent = totalDur + ' min au total';
}

function updateBookingSummary() {
  var sumSvc = document.getElementById('sum-svc');
  var sumDur = document.getElementById('sum-dur');
  var sumPrice = document.getElementById('sum-price');
  if (!sumSvc) return;
  if (selectedSoins.length === 0) {
    sumSvc.textContent = '—'; sumDur.textContent = '—'; sumPrice.textContent = '—'; return;
  }
  var totalPrice = selectedSoins.reduce(function(a, s) { return a + s.prix; }, 0);
  var totalDur = selectedSoins.reduce(function(a, s) { return a + s.dur; }, 0);
  sumSvc.textContent = selectedSoins.map(function(s) { return s.nom; }).join(' + ');
  sumDur.textContent = totalDur + ' min';
  sumPrice.textContent = totalPrice + ' € (acompte ' + Math.round(totalPrice * 0.2) + ' €)';
}


function renderCal(){
  document.getElementById('cal-month').textContent=MONTHS[curDate.getMonth()]+' '+curDate.getFullYear()
  const first=new Date(curDate.getFullYear(),curDate.getMonth(),1)
  const last=new Date(curDate.getFullYear(),curDate.getMonth()+1,0)
  let start=first.getDay()===0?6:first.getDay()-1,html=''
  for(let i=0;i<start;i++)html+='<div class="cal-day"></div>'
  for(let d=1;d<=last.getDate();d++){
    const dow=new Date(curDate.getFullYear(),curDate.getMonth(),d).getDay()
    const isWknd=dow===0||dow===6
    const isSel=selDate===d
    html+=`<div class="cal-day in-month${isWknd?' unavailable':' available'}${isSel?' selected':''}" ${!isWknd?`onclick="pickDay(${d})"`:''}>${d}</div>`
  }
  document.getElementById('cal-days').innerHTML=html
}

function pickDay(d){
  selDate=d;selSlot=null
  const ds=`${d} ${MONTHS[curDate.getMonth()]} ${curDate.getFullYear()}`
  document.getElementById('slots-label').textContent='Créneaux — '+ds
  document.getElementById('sum-date').textContent=ds
  document.getElementById('sum-time').textContent='—'
  renderCal();renderSlots()
  document.getElementById('slots-sec').style.display='block'
}

function renderSlots(){
  const times=['09:00','09:30','10:00','10:30','11:00','11:30','14:00','14:45','15:30','16:15','17:00']
  const full=['09:30','14:45']
  const last=['17:00']
  const grid=document.getElementById('slots-grid')
  grid.innerHTML=''
  times.forEach(function(t){
    const div=document.createElement('div')
    div.className='slot'+(full.includes(t)?' full':'')+(selSlot===t?' selected':'')
    div.textContent=t
    if(last.includes(t)){
      const tag=document.createElement('span')
      tag.className='slot-tag'
      tag.textContent='Dernier'
      div.appendChild(tag)
    }
    if(!full.includes(t)){
      div.addEventListener('click',function(){pickSlot(t)})
    }
    grid.appendChild(div)
  })
}

function pickSlot(t){selSlot=t;document.getElementById('sum-time').textContent=t;renderSlots()}

async function submitBooking(e){
  e.preventDefault()
  if(selectedSoins.length===0){showError('Sélectionnez au moins une prestation.');return}
  if(!selDate||!selSlot){showError('Sélectionnez une date et un créneau.');return}
  const totalPrice=selectedSoins.reduce(function(a,s){return a+s.prix},0)
  const totalDur=selectedSoins.reduce(function(a,s){return a+s.dur},0)
  const s={nom:selectedSoins.map(function(x){return x.nom}).join(' + '),dur:totalDur,prix:totalPrice}
  const btn=document.getElementById('bk-submit')
  btn.textContent='Envoi en cours...';btn.disabled=true
  hideAlerts()
  const fd=new FormData(e.target)
  const body={...Object.fromEntries(fd.entries()),service:s.nom,duration:String(s.dur),price:String(s.prix),date:`${selDate} ${MONTHS[curDate.getMonth()]} ${curDate.getFullYear()}`,time:selSlot}
  try{
    let ref=null
    try{
      const res=await fetch('/api/booking',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
      const ct=res.headers.get('content-type')||''
      if(ct.includes('application/json')){
        const data=await res.json()
        if(res.ok)ref=data.ref
      }
    }catch(_){}
    if(!ref)ref='RDV-'+Math.random().toString(36).slice(2,5).toUpperCase()+Math.floor(Math.random()*100)
    const data={ref}
    const suc=document.getElementById('bk-success')
    suc.style.display='block'
    suc.innerHTML=`✅ <strong>RDV confirmé !</strong> Réf. <strong>${data.ref}</strong><br>${s.name} le ${body.date} à ${selSlot}<br>Email envoyé · Acompte de ${Math.round(s.price*.2)} € sera prélevé.`
    e.target.reset();selDate=null;selSlot=null;renderCal();document.getElementById('slots-sec').style.display='none'
  }catch(er){showError(er.message||'Erreur. Réessayez ou appelez le 01 42 00 00 00.')}
  finally{btn.textContent='✅ Confirmer et payer l\'acompte';btn.disabled=false}
}
function showError(m){const el=document.getElementById('bk-error');el.style.display='block';el.textContent='❌ '+m}
function hideAlerts(){document.getElementById('bk-success').style.display='none';document.getElementById('bk-error').style.display='none'}

document.getElementById('cal-prev').onclick=()=>{curDate.setMonth(curDate.getMonth()-1);renderCal()}
document.getElementById('cal-next').onclick=()=>{curDate.setMonth(curDate.getMonth()+1);renderCal()}

renderSoins();renderCal();renderBA();renderTeam();renderAvis();renderFAQ()
</script>
</body>
</html>
