  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:2rem">
    <div style="font-family:'Syne',sans-serif;font-size:3rem;font-weight:800">4.9</div>
    <div><div style="color:#fbbf24;font-size:18px">★★★★★</div><div style="font-size:13px;color:var(--muted)">312 avis Google · Treatwell</div></div>
  </div>
